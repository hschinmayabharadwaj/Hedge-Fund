# Application Settings
APP_NAME=SecureBackendAPI
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Security Settings
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
JWT_SECRET_KEY=change-this-to-another-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Keys (Base64 encoded)
ENCRYPTION_KEY=generate-with-cryptography.fernet.Fernet.generate_key()
FIELD_ENCRYPTION_KEY=another-fernet-key-for-field-level-encryption

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/secure_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_SSL=True
REDIS_MAX_CONNECTIONS=50

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=your-kafka-username
KAFKA_SASL_PASSWORD=your-kafka-password
KAFKA_SSL_CA_LOCATION=/path/to/ca-cert
KAFKA_SSL_CERT_LOCATION=/path/to/client-cert
KAFKA_SSL_KEY_LOCATION=/path/to/client-key
KAFKA_CONSUMER_GROUP=secure-backend-group
KAFKA_TOPIC_PREFIX=secure-app

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# CORS Settings
CORS_ORIGINS=["https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=True

# Security Headers
ENABLE_HSTS=True
ENABLE_CSP=True
ENABLE_X_FRAME_OPTIONS=True
ENABLE_X_CONTENT_TYPE_OPTIONS=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_AUDIT_LOG=True

# MFA Settings
MFA_ENABLED=True
MFA_ISSUER_NAME=SecureBackendAPI

# Session Settings
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Monitoring
PROMETHEUS_ENABLED=True
METRICS_PORT=9090
